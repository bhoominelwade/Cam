{
  "expo": {
    "name": "Cam",
    "slug": "cam",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.astlin.cam",
      "infoPlist": {
        "NSCameraUsageDescription": "Cam uses the camera to show your live viewfinder and coach your shot. Nothing ever leaves your phone."
      }
    },
    "android": {
      "package": "com.astlin.cam",
      "permissions": [
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "ca0f00bb-49d9-4684-8d84-a2b06ee1b79f"
      }
    },
    "owner": "sensaisatori"
  }
}
